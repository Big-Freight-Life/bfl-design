# ── Contact form & notifications ────────────────────────────────────────
RESEND_API_KEY=
CONTACT_EMAIL=
SLACK_WEBHOOK_URL=

# ── Case study auth ─────────────────────────────────────────────────────
CASE_STUDY_PASSWORD=
# HMAC secret for signing case-study session cookies. Generate with:
#   openssl rand -hex 32
# Must be set in every environment (dev, preview, prod). Fails closed if missing.
CASE_STUDY_SESSION_SECRET=

# ── Raybot (chat endpoint) ──────────────────────────────────────────────
GEMINI_API_KEY=

# Upstash Redis — powers per-IP rate limiting, global rate limiting,
# per-IP lead capture cap, and lead idempotency. If unset, those guards
# are silently skipped (fine for local dev, not for production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: daily request budget (integer). Defaults to 1000 if unset.
# CHAT_DAILY_REQUEST_LIMIT=1000

# Optional: extra allowed origins for the chat endpoint (comma-separated).
# Localhost origins are always allowed in development.
# CHAT_ALLOWED_ORIGINS=

# ── Observability (optional) ────────────────────────────────────────────
# When both are set, audit events are forwarded to Axiom in addition to
# stdout. When either is missing, forwarding is a silent no-op.
# See docs/ops/log-drain-setup.md for setup.
# AXIOM_INGEST_URL=https://api.axiom.co/v1/datasets/bfl-design-chat/ingest
# AXIOM_API_TOKEN=
